{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schema/planetary-body.json",
  "title": "Planetary Body Reference",
  "type": "object",
  "required": [
    "superclusterReference",
    "galaxyClusterReference",
    "galaxyReference",
    "starSystemReference",
    "planetaryOrder"
  ],
  "properties": {
    "superclusterReference": {
      "type": "integer",
      "minimum": 1
    },
    "galaxyClusterReference": {
      "type": "integer",
      "minimum": 1
    },
    "galaxyReference": {
      "type": "integer",
      "minimum": 1
    },
    "starSystemReference": {
      "type": "integer",
      "minimum": 1
    },
    "planetaryOrder": {
      "type": "object",
      "required": [
        "numberingSystem",
        "order"
      ],
      "properties": {
        "numberingSystem": {
          "type": "string",
          "enum": [
            "all_planetary_bodies",
            "habitable_planets_only"
          ]
        },
        "order": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "additionalProperties": false
}
