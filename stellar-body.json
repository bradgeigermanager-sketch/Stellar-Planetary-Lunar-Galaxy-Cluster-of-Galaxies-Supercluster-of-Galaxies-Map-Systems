{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schema/stellar-body.json",
  "title": "Stellar Body Reference",
  "type": "object",
  "required": [
    "superclusterReference",
    "galaxyClusterReference",
    "galaxyReference",
    "starSystemReference",
    "stellarOrder"
  ],
  "properties": {
    "superclusterReference": {
      "type": "integer",
      "minimum": 1
    },
    "galaxyClusterReference": {
      "type": "integer",
      "minimum": 1
    },
    "galaxyReference": {
      "type": "integer",
      "minimum": 1
    },
    "starSystemReference": {
      "type": "integer",
      "minimum": 1
    },
    "stellarOrder": {
      "type": "integer",
      "minimum": 1,
      "description": "Numerical order of the star within the star system."
    }
  },
  "additionalProperties": false
}
